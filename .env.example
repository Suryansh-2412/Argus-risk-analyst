# FinAI Risk Analyst — API Keys
# Copy this to .env and fill in. Never commit .env to git.

# ── Required ──────────────────────────────────────────────────
# Free — register at https://finnhub.io (takes 30 seconds)
FINNHUB_API_KEY=your_finnhub_key_here

# ── Optional: better summarization ───────────────────────────
# Free tier — register at https://console.groq.com
# 30 req/min, 14,400 req/day — plenty for this project
# Only needed if you set models.summarizer.active: groq in config.yaml
GROQ_API_KEY=your_groq_key_here

# ── Paid (not recommended) ────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
